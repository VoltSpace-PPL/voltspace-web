#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <PZEM004Tv30.h>

const char* ssid = "adityakania";
const char* password = "aditya123";

String server = "http://192.168.100.6:8000/api";

#define RELAY_PIN 14

PZEM004Tv30 pzem(Serial2, 16, 17);

unsigned long lastRequest = 0;
unsigned long lastPzemSend = 0;

const unsigned long intervalRelay = 5000;   
const unsigned long intervalPzem  = 10000;  

void setup() {
  Serial.begin(115200);

  pinMode(RELAY_PIN, OUTPUT);
  digitalWrite(RELAY_PIN, HIGH); 

  Serial2.begin(9600, SERIAL_8N1, 16, 17);

  WiFi.begin(ssid, password);

  Serial.print("Connecting");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nConnected!");
  Serial.println(WiFi.localIP());
}

void loop() {
  if (WiFi.status() != WL_CONNECTED) return;

  if (millis() - lastRequest >= intervalRelay) {
    lastRequest = millis();
    kontrolRelay();
  }

  if (millis() - lastPzemSend >= intervalPzem) {
    lastPzemSend = millis();
    kirimPZEM();
  }
}

void kontrolRelay() {
  HTTPClient http;

  http.begin(server + "/iot/ruangan");
  int code = http.GET();

  if (code == 200) {
    String payload = http.getString();

    DynamicJsonDocument doc(4096);
    DeserializationError error = deserializeJson(doc, payload);

    if (error) {
      Serial.println(error.c_str());
      http.end();
      return;
    }

    JsonArray data = doc.as<JsonArray>();

    for (JsonObject room : data) {
      int power = room["power"] | 0;

      Serial.print("POWER: ");
      Serial.println(power);

      digitalWrite(RELAY_PIN, power ? LOW : HIGH);
    }
  }

  http.end();
}

void kirimPZEM() {
  float voltage = pzem.voltage();
  float current = pzem.current();
  float power   = pzem.power();
  float energy  = pzem.energy();

  if (isnan(voltage) || isnan(current) || isnan(power)) {
    Serial.println("PZEM read error");
    return;
  }

  Serial.println("=== PZEM DATA ===");
  Serial.println(voltage);
  Serial.println(current);
  Serial.println(power);
  Serial.println(energy);

  HTTPClient http;
  http.begin(server + "/iot/pzem");
  http.addHeader("Content-Type", "application/json");

  String body = "{";
  body += "\"voltage\":" + String(voltage) + ",";
  body += "\"current\":" + String(current) + ",";
  body += "\"power\":" + String(power) + ",";
  body += "\"energy\":" + String(energy);
  body += "}";

  int code = http.POST(body);

  Serial.print("PZEM POST: ");
  Serial.println(code);

  http.end();
}